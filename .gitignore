# Environment
.env

# Python cache
__pycache__/
**/__pycache__/
**pycache**/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Logs
*.log
logs/*
!logs/.gitkeep

# Generated metadata and local Zernio upload history
metadata/*.json
metadata/processed_urls.txt
!metadata/.gitkeep

# Downloaded and generated video files
*.mp4
*.mov
*.m4v
*.avi
*.mkv
*.webm
*.mpg
*.mpeg

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.part*
*.ytdl
tmp/
temp/
.DS_Store
Thumbs.db

# Keep placeholder files tracked
!.gitkeep
!**/.gitkeep
